{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Island",
  "version": "0.1.0",
  "identifier": "app.vibeisland.VibeIsland",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vibe Island",
        "width": 340,
        "height": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": false,
        "visible": true,
        "center": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
